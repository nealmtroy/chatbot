# --- Telegram Userbot Credentials ---
# Dapatkan API_ID & API_HASH di https://my.telegram.org
# Setiap account (Alya/Intan/Vanya) punya session file & creds sendiri,
# tapi bisa pakai API_ID/HASH yang SAMA (1 aplikasi my.telegram.org).
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# --- AI Provider Selection ---
# Pilih "GROQ" atau "OPENROUTER"
SELECTED_PROVIDER=GROQ

# --- Groq ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=qwen/qwen3-32b

# --- OpenRouter ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free

# --- Manage Bot (Telegram BOT untuk owner kelola account) ---
# Buat bot di @BotFather, masukkan token di sini.
MANAGE_BOT_TOKEN=your_manage_bot_token_here
# ID Telegram owner (angka, cari di @userinfobot). Cuma dia yg bisa pakai manage bot.
OWNER_ID=your_telegram_id_here

# --- DB ---
# Nama file SQLite (default chatbot.db)
DB_FILE=chatbot.db

# --- Integrasi QRIS VIP (sociabuzz-pay) ---
# Username Sociabuzz tujuan (TRIBE tempat donasi). Kosong = QRIS off.
SOCIABUZZ_USERNAME=
# (Opsional) Cookie browser kalau CSRF butuh auth. Biasanya kosong aman.
SOCIABUZZ_COOKIE=
# Path ke folder sociabuzz-pay. KOSONG = auto-detect parent folder
# (karena chatbot ada di sociabuzz-pay/telegram-chatbot/).
SOCIABUZZ_PAY_PATH=
# Interval polling cek status QRIS (detik). Default 10.
PAYMENT_POLL_INTERVAL=10
