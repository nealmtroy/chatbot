# --- Telegram Userbot Credentials ---
# Dapatkan API_ID & API_HASH di https://my.telegram.org
# Setiap account (Alya/Intan/Vanya) punya session file & creds sendiri,
# tapi bisa pakai API_ID/HASH yang SAMA (1 aplikasi my.telegram.org).
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# --- AI Provider Selection ---
# Pilih "GROQ" atau "OPENROUTER"
SELECTED_PROVIDER=GROQ

# --- Groq ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=qwen/qwen3-32b

# --- OpenRouter ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free

# --- Manage Bot & VIP Payment Bot (Role-Based Access Control) ---
# Buat bot di @BotFather, masukkan token di sini.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
MANAGE_BOT_TOKEN=your_manage_bot_token_here
# ID Telegram Owner (pisahkan dengan koma jika lebih dari 1 ID). Punya akses Penuh: Log Chat, Packages, Multi-Bot.
OWNER_IDS=123456789
# ID Telegram Admin (operator/CS). Akses: Login akun, kelola persona, upload media, konfirmasi bayar.
ADMIN_IDS=111222333,444555666

# --- DB ---
# Nama file SQLite (default chatbot.db)
DB_FILE=chatbot.db

# --- Integrasi QRIS VIP (SociaBuzz Payment Engine) ---
# Username Sociabuzz tujuan (TRIBE tempat donasi). Kosong = QRIS off.
SOCIABUZZ_USERNAME=your_sociabuzz_username
# (Opsional) Cookie browser kalau CSRF memerlukan auth.
SOCIABUZZ_COOKIE=
# Interval polling cek status QRIS (detik). Default 10.
PAYMENT_POLL_INTERVAL=10

# Fallback VIP & Log Chat ID
VIP_CHAT_ID=
LOG_CHAT_ID=

# --- Native PostgreSQL Database (Self-Hosted / VPS) ---
# Direct connection string ke PostgreSQL tanpa Supabase / HTTP SDK (100% Gratis & Fast)
DATABASE_URL=postgresql://postgres:postgres_password@localhost:5432/vip_db

# (Opsional) Supabase Cloud HTTP Fallback jika tidak menggunakan PostgreSQL lokal
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
